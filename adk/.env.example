# LLM provider: openai (default) | gemini
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini

# Google AI API key (only needed if LLM_PROVIDER=gemini)
GOOGLE_API_KEY=

# Gemini model (only used when LLM_PROVIDER=gemini)
GEMINI_MODEL=gemini-2.5-flash-lite

# OpenAI API key (chat + voice STT/TTS)
OPENAI_API_KEY=

# Agent switcher: crm (default) | shopassist
AGENT_MODE=crm
# AGENT_USE_TOOLS=true

# Public URL for product image links (match EXPO_PUBLIC_API_URL in botbotbot/.env)
API_PUBLIC_URL=http://127.0.0.1:8000

# Postgres (asyncpg required by ADK DatabaseSessionService)
# Host 5432 may be busy; use: POSTGRES_PORT=5433 docker compose up -d
DATABASE_URL=postgresql+asyncpg://botbotbot:botbotbot@127.0.0.1:5433/botbotbot
