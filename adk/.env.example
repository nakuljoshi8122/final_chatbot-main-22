# LLM provider: openai (default) | gemini
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini

# Google AI API key (only needed if LLM_PROVIDER=gemini)
GOOGLE_API_KEY=

# Gemini model (only used when LLM_PROVIDER=gemini)
GEMINI_MODEL=gemini-2.5-flash-lite

# OpenAI API key (chat + voice STT/TTS)
OPENAI_API_KEY=

# Agent switcher: crm (default) | adidas
AGENT_MODE=crm
# AGENT_USE_TOOLS=true

# Public URL for product image links (match EXPO_PUBLIC_API_URL in botbotbot/.env)
API_PUBLIC_URL=http://127.0.0.1:8000

# Postgres (asyncpg required by ADK DatabaseSessionService)
# Default docker-compose maps host 5432→container 5432.
# If host 5432 is busy, run: POSTGRES_PORT=5433 docker compose up -d
# and point DATABASE_URL at that host port.
DATABASE_URL=postgresql+asyncpg://botbotbot:botbotbot@127.0.0.1:5432/botbotbot
